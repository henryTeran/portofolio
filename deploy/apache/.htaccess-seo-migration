RewriteEngine On

# ----------------------------------------------------------------------
# Canonical domain: HTTPS + non-WWW
# ----------------------------------------------------------------------
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.henryteran\.com$ [NC]
RewriteRule ^ https://henryteran.com%{REQUEST_URI} [R=301,L,NE]

# ----------------------------------------------------------------------
# 301 migration from ?lang=fr|en|es to /fr|/en|/es routes
# Preserves additional query params by rebuilding query string with %1 and %3.
# ----------------------------------------------------------------------

# /?lang=xx
RewriteCond %{REQUEST_URI} ^/?$ [NC]
RewriteCond %{REQUEST_URI} !^/(fr|en|es)(/|$) [NC]
RewriteCond %{QUERY_STRING} ^(.*?)(?:^|&)lang=(fr|en|es)(?:&(.*))?$ [NC]
RewriteRule ^$ /%2/?%1%3 [R=301,L,NE]

# /services?lang=xx
RewriteCond %{REQUEST_URI} ^/services/?$ [NC]
RewriteCond %{REQUEST_URI} !^/(fr|en|es)(/|$) [NC]
RewriteCond %{QUERY_STRING} ^(.*?)(?:^|&)lang=(fr|en|es)(?:&(.*))?$ [NC]
RewriteRule ^services/?$ /%2/services?%1%3 [R=301,L,NE]

# /projects?lang=xx
RewriteCond %{REQUEST_URI} ^/projects/?$ [NC]
RewriteCond %{REQUEST_URI} !^/(fr|en|es)(/|$) [NC]
RewriteCond %{QUERY_STRING} ^(.*?)(?:^|&)lang=(fr|en|es)(?:&(.*))?$ [NC]
RewriteRule ^projects/?$ /%2/projects?%1%3 [R=301,L,NE]

# /contact?lang=xx
RewriteCond %{REQUEST_URI} ^/contact/?$ [NC]
RewriteCond %{REQUEST_URI} !^/(fr|en|es)(/|$) [NC]
RewriteCond %{QUERY_STRING} ^(.*?)(?:^|&)lang=(fr|en|es)(?:&(.*))?$ [NC]
RewriteRule ^contact/?$ /%2/contact?%1%3 [R=301,L,NE]

# Cleanup accidental leading/trailing & in query string after redirect rebuild
RewriteCond %{QUERY_STRING} ^&(.*)$
RewriteRule ^ %{REQUEST_URI}?%1 [R=301,L,NE]
RewriteCond %{QUERY_STRING} ^(.*)&$
RewriteRule ^ %{REQUEST_URI}?%1 [R=301,L,NE]
RewriteCond %{QUERY_STRING} ^(.*)&&+(.*)$
RewriteRule ^ %{REQUEST_URI}?%1&%2 [R=301,L,NE]

# ----------------------------------------------------------------------
# SPA fallback for Vite build
# ----------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
